{
  "name": "node-sandbox-terminal",
  "version": "1.0.0",
  "description": "MCP server for sandboxed terminal sessions with controlled folder access using Node.js",
  "main": "dist/index.js",
  "bin": {
    "node-sandbox-terminal": "./run.js"
  },
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "mcp:dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "dockerode": "^4.0.2",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "minimatch": "^9.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.23",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "keywords": ["mcp", "sandbox", "terminal", "docker"],
  "author": "",
  "license": "MIT"
}